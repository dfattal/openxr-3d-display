+// ── Headless initialization (external VulkanContext, no window/swapchain) ─────
+void Renderer::initializeHeadless(std::shared_ptr<VulkanContext> externalContext,
+                                  const std::string& plyPath,
+                                  uint32_t renderWidth, uint32_t renderHeight) {
+    headless = true;
+    context = externalContext;
+    width = renderWidth;
+    height = renderHeight;
+
+    // Load scene
+    scene = std::make_shared<GSScene>(plyPath);
+    scene->load(context);
+
+    // Create uniform buffer
+    uniformBuffer = std::make_shared<Buffer>(context, sizeof(UniformBuffer),
+        VK_BUFFER_USAGE_UNIFORM_BUFFER_BIT,
+        VMA_MEMORY_USAGE_CPU_TO_GPU, true);
+
+    // Create vertex attribute buffer (2 * numVertices for tile overlap)
+    uint32_t numVertices = scene->getNumVertices();
+    vertexAttributeBuffer = std::make_shared<Buffer>(context,
+        sizeof(VertexAttribute) * numVertices,
+        VK_BUFFER_USAGE_STORAGE_BUFFER_BIT,
+        VMA_MEMORY_USAGE_GPU_ONLY, false);
+
+    // Create tile overlap buffer, prefix sum buffers, sort buffers, etc.
+    // (same initialization as in initializeVulkan() but without swapchain)
+    uint32_t numTilesX = (renderWidth + TILE_WIDTH - 1) / TILE_WIDTH;
+    uint32_t numTilesY = (renderHeight + TILE_HEIGHT - 1) / TILE_HEIGHT;
+    uint32_t numTiles = numTilesX * numTilesY;
+
+    tileOverlapBuffer = std::make_shared<Buffer>(context,
+        sizeof(uint32_t) * numVertices,
+        VK_BUFFER_USAGE_STORAGE_BUFFER_BIT,
+        VMA_MEMORY_USAGE_GPU_ONLY, false);
+
+    prefixSumPingBuffer = std::make_shared<Buffer>(context,
+        sizeof(uint32_t) * numVertices,
+        VK_BUFFER_USAGE_STORAGE_BUFFER_BIT | VK_BUFFER_USAGE_TRANSFER_DST_BIT,
+        VMA_MEMORY_USAGE_GPU_ONLY, false);
+
+    prefixSumPongBuffer = std::make_shared<Buffer>(context,
+        sizeof(uint32_t) * numVertices,
+        VK_BUFFER_USAGE_STORAGE_BUFFER_BIT,
+        VMA_MEMORY_USAGE_GPU_ONLY, false);
+
+    totalSumBufferHost = std::make_shared<Buffer>(context,
+        sizeof(uint32_t),
+        VK_BUFFER_USAGE_TRANSFER_DST_BIT,
+        VMA_MEMORY_USAGE_CPU_ONLY, true);
+
+    // Sort buffers (sized for max possible instances = numVertices * maxTilesPerGaussian)
+    uint32_t maxInstances = numVertices * 4;  // Conservative estimate
+    sortKVEven = std::make_shared<Buffer>(context, sizeof(uint64_t) * maxInstances,
+        VK_BUFFER_USAGE_STORAGE_BUFFER_BIT, VMA_MEMORY_USAGE_GPU_ONLY, false);
+    sortKVOdd = std::make_shared<Buffer>(context, sizeof(uint64_t) * maxInstances,
+        VK_BUFFER_USAGE_STORAGE_BUFFER_BIT, VMA_MEMORY_USAGE_GPU_ONLY, false);
+    sortHistBuffer = std::make_shared<Buffer>(context, sizeof(uint32_t) * 256 * 32,
+        VK_BUFFER_USAGE_STORAGE_BUFFER_BIT, VMA_MEMORY_USAGE_GPU_ONLY, false);
+
+    tileBoundaryBuffer = std::make_shared<Buffer>(context,
+        sizeof(uint32_t) * numTiles * 2,
+        VK_BUFFER_USAGE_STORAGE_BUFFER_BIT,
+        VMA_MEMORY_USAGE_GPU_ONLY, false);
+
+    // Create compute pipelines (preprocess, prefix sum, sort, tile boundary, render)
+    createPreprocessPipeline();
+    createPrefixSumPipeline();
+    createPreprocessSortPipeline();
+    createRadixSortPipeline();
+    createTileBoundaryPipeline();
+    createRenderPipeline();
+
+    // Record preprocess command buffer (reusable)
+    recordPreprocessCommandBuffer();
+
+    spdlog::info("Renderer: headless init complete ({} vertices, {}x{} render target)",
+                 numVertices, renderWidth, renderHeight);
+}
+
+// ── Render single view to external image ─────────────────────────────────────
+void Renderer::renderToExternal(VkImage targetImage,
+                                VkImageView targetImageView,
+                                VkFormat format,
+                                uint32_t targetWidth, uint32_t targetHeight,
+                                uint32_t viewportX, uint32_t viewportY,
+                                uint32_t viewportWidth, uint32_t viewportHeight,
+                                const glm::mat4& viewMatrix,
+                                const glm::mat4& projMatrix) {
+    // Update uniform buffer with provided view/projection
+    auto* ub = static_cast<UniformBuffer*>(uniformBuffer->map());
+    ub->view_mat = viewMatrix;
+    ub->proj_mat = projMatrix;
+    ub->camera_position = glm::vec4(
+        glm::inverse(viewMatrix)[3]);  // Extract camera position from view matrix
+    ub->width = viewportWidth;
+    ub->height = viewportHeight;
+    float aspect = (float)viewportWidth / (float)viewportHeight;
+    // Extract FOV from projection matrix
+    ub->tan_fovx = 1.0f / projMatrix[0][0];
+    ub->tan_fovy = 1.0f / projMatrix[1][1];
+    uniformBuffer->unmap();
+
+    auto& queue = context->queues[Queue::Type::COMPUTE].queue;
+
+    // Submit preprocess (prerecorded command buffer)
+    vk::SubmitInfo preprocessSubmit;
+    preprocessSubmit.commandBufferCount = 1;
+    preprocessSubmit.pCommandBuffers = &preprocessCommandBuffer;
+    queue.submit(preprocessSubmit);
+    queue.waitIdle();
+
+    // Read total instances from host buffer
+    uint32_t numInstances = *static_cast<uint32_t*>(totalSumBufferHost->map());
+    totalSumBufferHost->unmap();
+    if (numInstances == 0) return;
+
+    // Update render pipeline's output image descriptor to point at target
+    updateRenderOutputDescriptor(targetImageView, viewportX, viewportY,
+                                 viewportWidth, viewportHeight);
+
+    // Record and submit render command buffer
+    recordRenderCommandBuffer(targetImage, numInstances,
+                              viewportX, viewportY, viewportWidth, viewportHeight);
+
+    vk::SubmitInfo renderSubmit;
+    renderSubmit.commandBufferCount = 1;
+    renderSubmit.pCommandBuffers = &renderCommandBuffer;
+    queue.submit(renderSubmit);
+    queue.waitIdle();
+}
