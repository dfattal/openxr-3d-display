+// ── External-ownership factory ──────────────────────────────────────────
+std::shared_ptr<VulkanContext> VulkanContext::createFromExternal(
+    VkInstance instance,
+    VkPhysicalDevice physicalDevice,
+    VkDevice device,
+    VkQueue computeQueue,
+    uint32_t computeQueueFamily,
+    uint32_t computeQueueIndex)
+{
+    // Create with empty extensions — we skip instance/device creation entirely
+    auto ctx = std::make_shared<VulkanContext>(
+        std::vector<std::string>{}, std::vector<std::string>{}, false);
+    ctx->externalOwnership = true;
+
+    // Store raw handles via non-owning unique wrappers.
+    // Release existing unique handles first (they were default-constructed).
+    ctx->instance.release();
+    ctx->device.release();
+
+    // Re-wrap as non-owning: we use the raw handle but the UniqueHandle
+    // won't destroy it because we'll release() in the destructor path.
+    // Instead, store as raw and access via get().
+    // Simpler approach: just set the raw handles on the vk::Unique* objects
+    // with a custom approach.  Actually the cleanest way is to use
+    // ObjectDestroy with a no-op deleter.  But that's complex with vulkan.hpp.
+    //
+    // Pragmatic solution: wrap in Unique and release() on destruction.
+    ctx->instance = vk::UniqueInstance(vk::Instance(instance));
+    ctx->physicalDevice = vk::PhysicalDevice(physicalDevice);
+    ctx->device = vk::UniqueDevice(vk::Device(device));
+
+    // Set up the compute queue
+    Queue q;
+    q.queue = vk::Queue(computeQueue);
+    q.familyIndex = computeQueueFamily;
+    q.index = computeQueueIndex;
+    ctx->queues[Queue::Type::COMPUTE] = q;
+    ctx->queues[Queue::Type::GRAPHICS] = q;  // Use same queue for both
+
+    // Set up VMA allocator with external handles
+    VmaAllocatorCreateInfo allocatorInfo = {};
+    allocatorInfo.instance = instance;
+    allocatorInfo.physicalDevice = physicalDevice;
+    allocatorInfo.device = device;
+    allocatorInfo.vulkanApiVersion = VK_API_VERSION_1_2;
+    VmaAllocator allocator;
+    vmaCreateAllocator(&allocatorInfo, &allocator);
+    ctx->allocator = allocator;
+
+    // Create command pool
+    vk::CommandPoolCreateInfo poolInfo;
+    poolInfo.flags = vk::CommandPoolCreateFlagBits::eResetCommandBuffer;
+    poolInfo.queueFamilyIndex = computeQueueFamily;
+    ctx->commandPool = ctx->device->createCommandPoolUnique(poolInfo);
+
+    // Create descriptor pool with generous limits
+    ctx->createDescriptorPool(4);
+
+    spdlog::info("VulkanContext: initialized from external Vulkan handles "
+                 "(queue family {})", computeQueueFamily);
+
+    return ctx;
+}
