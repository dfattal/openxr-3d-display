{
  "name": "webxr-bridge",
  "version": "1.0.0",
  "private": true,
  "description": "WebXR-to-OpenXR bridge for Monado runtime on macOS",
  "scripts": {
    "build": "esbuild extension/src/index.js --bundle --outfile=extension/webxr-polyfill-bundle.js --format=iife --target=chrome100",
    "watch": "esbuild extension/src/index.js --bundle --outfile=extension/webxr-polyfill-bundle.js --format=iife --target=chrome100 --watch"
  },
  "dependencies": {
    "gl-matrix": "^3.4.3",
    "webxr-polyfill": "^2.0.3"
  },
  "devDependencies": {
    "esbuild": "^0.20.0"
  }
}
